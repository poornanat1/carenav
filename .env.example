# Copy to `.env` and fill in. Vars are bare (no prefix); see src/carenav/config.py.
# `.env` is gitignored — never commit real keys.

ENV=local

# --- database ---
# Host runs: localhost. Inside docker-compose, the app service overrides this to `db`.
DATABASE_URL=postgresql+psycopg://carenav:carenav@localhost:5432/carenav

# --- models (Mistral default) ---
MODEL_PROVIDER=mistral
MODEL_SMALL=mistral-small-latest
MODEL_FRONTIER=mistral-large-latest

# Reaching Mistral — an API key is REQUIRED (embeddings are always real). It serves both
# chat generation and embeddings. Get one from https://console.mistral.ai/
MISTRAL_API_KEY=

# Force the offline stub generator (embeddings stay real). Useful when a key has
# embedding quota but no chat quota, or to run the loop without spend.
# STUB_GENERATION=false

# --- data pipeline (kept small for a reproducible demo) ---
SYNTHEA_POPULATION=200
NPPES_MAX_PROVIDERS=5000
NPPES_STATES=NJ,NY
