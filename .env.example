# Copy to `.env` and fill in. Vars are bare (no prefix); see src/carenav/config.py.
# `.env` is gitignored — never commit real keys.

ENV=local

# --- database ---
# Host runs: localhost. Inside docker-compose, the app service overrides this to `db`.
DATABASE_URL=postgresql+psycopg://carenav:carenav@localhost:5432/carenav

# --- models (Fireworks default) ---
MODEL_PROVIDER=fireworks
MODEL_SMALL=accounts/fireworks/models/gpt-oss-20b
MODEL_FRONTIER=accounts/fireworks/models/gpt-oss-120b

# Reaching Mistral — an API key is REQUIRED (embeddings are always real). It serves both
# chat generation and embeddings. Get one from https://console.mistral.ai/
MISTRAL_API_KEY=

# Fireworks powers generation and PII fine-tuning by default.
FIREWORKS_API_KEY=
# Optional; if omitted, `make train-pii` discovers the account when the key has access to one.
FIREWORKS_ACCOUNT_ID=
# Set after deployment. Multi-LoRA routes use: <fine_tuned_model>#<deployment>.
# PII_MODEL=accounts/<account-id>/models/<model-id>#accounts/<account-id>/deployments/<deployment-id>
PII_BASE_MODEL=accounts/fireworks/models/llama-v3p1-8b-instruct
PII_OUTPUT_MODEL=carenav-pii-detector

# Force the offline stub generator (embeddings stay real). Useful when a key has
# embedding quota but no chat quota, or to run the loop without spend.
# STUB_GENERATION=false

# --- embeddings / vector store ---
# Keep EMBEDDING_DIM aligned with the embedding model and the pgvector column.
EMBEDDING_MODEL=mistral-embed
EMBEDDING_DIM=1024
RAG_TOP_K=5
RAG_RELEVANCE_MARGIN=0.045
RAG_LEX_WEIGHT=0.1

# --- data pipeline (kept small for a reproducible demo) ---
SYNTHEA_POPULATION=200
NPPES_MAX_PROVIDERS=5000
NPPES_STATES=NJ,NY
